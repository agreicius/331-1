<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="s_PID_mod_proofs" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>PID-module structure theorems: proofs</title>
<theorem xml:id="th_pid_aligned_basis">
   <title>PID-module theorem: aligned bases</title>
   <statement>
   <p>
   Let <m>R</m> be a PID. Let <m>M</m> be free <m>R</m>-module of finite rank <m>m</m>, and let <m>N</m> be a nonzero submodule of <m>M</m>. 
   <ol>
    <li>
        <p>
            <m>N</m> is a free <m>R</m>-module and <m>\rank N\leq m</m>.
        </p>
    </li>
    <li>
        <p>
            There is a basis <m>B=(m_i)_{i=1}^m</m> of <m>M</m> and nonzero elements <m>a_1,a_2,\dots, a_n\in R</m>, <m>n\leq m</m>, such that
            <md number="yes">
                <mrow>a_i \amp \mid a_{i+1}</mrow>
            </md>
            for all <m>1\leq i\leq n-1</m>, and 
            <md number="yes">
                <mrow>B' \amp =(a_im_i)_{i=1}^{n}</mrow>
            </md>           
            is a basis of <m>N</m>. 
        </p>
    </li>
   </ol>
   </p>
   </statement>
   <proof>
   <p>
   </p>
   </proof>
   </theorem>
   <definition xml:id="d_aligned_basis">
   <title>Aligned basis</title>
   <statement>
   <p>
   Let <m>R</m> be a commutative ring, let <m>M</m> be a free <m>R</m>-module, and let <m>N</m> be a free submodule of <m>M</m>. An <term>aligned basis</term> for <m>M</m> and <m>N</m> is a basis <m>B=(m_i)_{i\in I}</m> of <m>M</m> such that there is a subset <m>J\subseteq I</m> and tuple <m>(a_j)_{j\in J}</m> of elements in <m>R</m> such that <m>B'=(a_jm_j)_{j\in J}</m> is a basis of <m>N</m>.
   </p>
   </statement>
   </definition>
   <example xml:id="eg_gauss_ints_aligned_basis">
   <title>Aligned basis for <m>\Z[i]</m> as <m>\Z</m>-module</title>
   <statement>
   <p>
   Let <m>R=\Z[i]</m>, the ring of Gaussian integers, and let <m>\alpha=1+2i</m>. 
   <ol>
    <li>
        <p>
            Show that <m>M=\Z[i]</m>, considered as a <m>\Z</m>-module, is free of rank 2. 
        </p>
    </li>
    <li>
        <p>
            Let <m>N</m> be the ideal of <m>\Z[i]</m> generated by <m>\alpha</m>: <ie/>, <m>N=\alpha\Z[i]</m>. Show that <m>N</m> is a free <m>\Z</m>-module of rank 2, and that <m>(1+2i, -2+i)</m> is a <m>\Z</m>-basis of <m>N</m>. 
        </p>
    </li>
    <li>
        <p>
            Note that the standard <m>\Z</m>-basis <m>(1,i)</m> of <m>\Z[i]</m> is not an aligned basis of <m>M</m> and <m>N</m>. Show that <m>(1+2i,i)</m> is an aligned basis for <m>M</m> and <m>N</m>. 
        </p>
    </li>

   </ol>
   </p>
   </statement>
   <solution>
   <p>
   
   </p>
   </solution>
   </example>
    

</section>