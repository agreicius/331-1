\draw (-10,0) -- (10,0) ;
\draw (0,-10) -- (0,10) ;
\foreach \x in {-8,-7,...,8}{% Two indices running over each
      \foreach \y in {-8,-7,...,8}{% node on the grid we have drawn 
        \node[draw,circle,blue!60,inner sep=2pt,fill] at (\x,\y) {};
            % Places a dot at those points
      }
  }
\node[anchor=south east] at (0,1) {\footnotesize $i$};
\node[anchor=south east] at (0,2) {\footnotesize $2i$};
\node[anchor=south east] at (0,-1) {\footnotesize $-i$};
\node[anchor=south east] at (0,-2) {\footnotesize $-2i$};


\foreach \x in {-5,-4,-3,-2,-1,1,2,3,4,5}% Two indices running over each
      \node[anchor=north] at (\x,0) {$\x$};

% 1 Connect points along second basis vector
\foreach \x in {-5,-4,...,5}{
  \foreach \y in {-5,-4,...,5}{ % stops at 1 so y+1 stays within {-3,...,2}
    \pgfmathsetmacro{\Xone}{\x - 2*\y}
    \pgfmathsetmacro{\Yone}{2*\x + \y}
