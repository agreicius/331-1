    \pgfmathsetmacro{\Ytwo}{2*\x + (\y + 1)}
    \draw[magenta!70, line width=0.6pt] (\Xone,\Yone) -- (\Xtwo,\Ytwo);
  }
}

% 2 Connect points along first basis vector
\foreach \y in {-5,-4,...,5}{
  \foreach \x in {-5,-4,...,4}{ % stops at 4 so x+1 stays within {-5,...,5}
    \pgfmathsetmacro{\Xone}{\x - 2*\y}
    \pgfmathsetmacro{\Yone}{2*\x + \y}
    \pgfmathsetmacro{\Xtwo}{(\x + 1) - 2*\y}
    \pgfmathsetmacro{\Ytwo}{2*(\x + 1) + \y}
    \draw[magenta!70, line width=0.6pt] (\Xone,\Yone) -- (\Xtwo,\Ytwo);
  }
}

 \foreach \x in {-5,-4,...,5}{% Two indices running over each
      \foreach \y in {-5,-4,...,5}{% node on the grid we have drawn 
        \node[magenta, scale=2] at (\x-2*\y,2*\x+\y) {$*$};
            % Places a dot at those points
      }
    }
